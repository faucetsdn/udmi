{
  "include": "prod_pod.json",
  "flow_defaults": {
    "protocol": "mqtt",
    "transport": "ssl",
    "hostname": "localhost",
    "ca_file": "/etc/mosquitto/certs/ca.crt",
    "cert_file": "/etc/mosquitto/certs/rsa_private.crt",
    "key_file": "/etc/mosquitto/certs/rsa_private.pem",
    "auth_provider": {
      "basic": {
        "username": "rocket",
        "password": "monkey"
      }
    }
  },
  "flows": {
    "reflect": {
      "recv_id": "reflect",
      "send_id": "c/control"
    },
    "target": {
      "recv_id": "events/#"
    },
    "state": {
      "recv_id": "state"
    },
    "control": {
      "recv_id": "c/control/#"
    },
    "provision": {
      "recv_id": "events/discovery",
      "send_id": "events",
      "enabled": "yes"
    },
    "distributor": {
      "enabled": "false"
    },
    "uufi": {
      "recv_id": "/uufi/#",
      "send_id": "${UDMI_PREFIX}udmi_target"
    }
  },
  "crons": {
    "sendgroot": {
      "send_id": "c/control"
    }
  },
  "iot_access": {
    "iot-access": {
      "project_id": "implicit"
    },
    "implicit": {
      "provider": "implicit",
      "options": "enabled=${ETCD_CLUSTER}",
      "endpoint": {
        "protocol": "mqtt",
        "transport": "ssl",
        "hostname": "localhost",
        "port": 8883,
        "ca_file": "/etc/mosquitto/certs/ca.crt",
        "cert_file": "/etc/mosquitto/certs/rsa_private.crt",
        "key_file": "/etc/mosquitto/certs/rsa_private.pem",
        "auth_provider": {
          "basic": {
            "username": "scrumptious",
            "password": "aardvark"
          }
        }
      }
    }
  }
}
