#!/bin/bash -eu

UDMI_ROOT=$(dirname $0)/..
source $UDMI_ROOT/etc/shell_common.sh

source $UDMI_ROOT/etc/mosquitto_ctrl.sh

SUDO=sudo
if [[ ${UDMI_NO_SUDO:-false} == true ]]; then
    SUDO=""
fi

if [[ -f $ETC_DIR/mosquitto.pid ]]; then
    OLD_PID=$(cat $ETC_DIR/mosquitto.pid)
    if ps -p $OLD_PID > /dev/null 2>&1; then
        echo "Killing existing local mosquitto process with PID $OLD_PID..."
        kill $OLD_PID || true
        sleep 1
    fi
fi

if [[ ${UDMI_NO_SUDO:-false} == true ]]; then
    MOSQUITTO_LOG=$ETC_DIR/log/mosquitto.log
else
    MOSQUITTO_LOG=/var/log/mosquitto/mosquitto.log
fi

# This is not already set-up when running inside of docker...
if [[ ! -f $ETC_DIR/mosquitto.conf ]]; then
    echo Installing base mosquitto.conf...
    $SUDO mkdir -p $ETC_DIR
    if [[ ${UDMI_NO_SUDO:-false} == true ]]; then
        $SUDO mkdir -p $ETC_DIR/log $ETC_DIR/data $ETC_DIR/conf.d
        cat <<EOF > $ETC_DIR/mosquitto.conf
pid_file $ETC_DIR/mosquitto.pid
persistence true
persistence_location $ETC_DIR/data/

log_dest file $MOSQUITTO_LOG

include_dir $ETC_DIR/conf.d
EOF
    else
        $SUDO cp $UDMI_ROOT/var/mosquitto.conf $ETC_DIR/ ||
            $SUDO cp $UDMI_ROOT/etc/mosquitto.conf $ETC_DIR/ ||
            fail fallback mosquitto.conf file not found.
    fi
fi

GROUP=mosquitto
UDMI_FILE=$ETC_DIR/conf.d/udmi.conf
PASS_FILE=$ETC_DIR/mosquitto.passwd
DYN_FILE=$ETC_DIR/dynamic_security.json

$SUDO mkdir -p $(dirname $MOSQUITTO_LOG)
if [[ -z $SUDO ]]; then
    $SUDO mkdir -p $ETC_DIR/data
else
    $SUDO chown mosquitto:mosquitto $(dirname $MOSQUITTO_LOG) || true
    $SUDO mkdir -p /var/lib/mosquitto
    $SUDO chown -R mosquitto:mosquitto /var/lib/mosquitto || true
fi

    PLUGIN_FILE=/usr/lib/mosquitto_dynamic_security.so
    [[ -f $PLUGIN_FILE ]] || PLUGIN_FILE=/usr/lib/mosquitto/mosquitto_dynamic_security.so
    [[ -f $PLUGIN_FILE ]] || PLUGIN_FILE=/usr/lib/x86_64-linux-gnu/mosquitto_dynamic_security.so
    [[ -f $PLUGIN_FILE ]] || PLUGIN_FILE=$(find /usr -name mosquitto_dynamic_security.so 2>/dev/null | head -1)
    [[ -n $PLUGIN_FILE ]] || fail "mosquitto_dynamic_security.so not found."

if [[ ! -f $UDMI_FILE ]]; then
    echo Creating new $UDMI_FILE from template...
    $SUDO mkdir -p $(dirname $UDMI_FILE)
    if [[ ${UDMI_NO_SUDO:-false} == true ]]; then
        $SUDO cp $UDMI_ROOT/etc/mosquitto_udmi.conf $UDMI_FILE
        # Replace hardcoded listener and paths in local mode
        $SUDO sed -i "s%listener 8883%listener ${MQTT_PORT:-8883}%" $UDMI_FILE
        $SUDO sed -i "s%/etc/mosquitto/mosquitto.passwd%$PASS_FILE%" $UDMI_FILE
        $SUDO sed -i "s%plugin_opt_config_file dynsec%plugin_opt_config_file $DYN_FILE%" $UDMI_FILE
        $SUDO sed -i "s%/etc/mosquitto/certs/%$CERT_DIR/%" $UDMI_FILE
    else
        $SUDO cp $UDMI_ROOT/etc/mosquitto_udmi.conf $UDMI_FILE
    fi
fi

# Always ensure correct dynamic security plugin, password file, and config file paths are set
echo Configuring dynamic security plugin $PLUGIN_FILE
$SUDO sed -i "s%plugin .*%plugin $PLUGIN_FILE%" $UDMI_FILE
$SUDO sed -i "s%plugin_opt_config_file .*%plugin_opt_config_file $DYN_FILE%" $UDMI_FILE
$SUDO sed -i "s%password_file .*%password_file $PASS_FILE%" $UDMI_FILE
$SUDO sed -i "s%listener [0-9]*%listener ${MQTT_PORT:-8883}%" $UDMI_FILE
[[ $(whoami) == root ]] && ! grep -q "^user root" $UDMI_FILE && echo "user root" >> $UDMI_FILE

# Ensure the mosquitto group can write to the config directory (required for atomic configuration saves)
if [[ -n $SUDO ]]; then
    $SUDO chgrp $GROUP $ETC_DIR || true
    $SUDO chmod 775 $ETC_DIR || true
fi

if [[ ! -f $DYN_FILE ]]; then
    echo Creating new $DYN_FILE
    echo Configuring MQTT user: $AUTH_USER
    $SUDO mosquitto_ctrl dynsec init $DYN_FILE $AUTH_USER $AUTH_PASS
fi

# Ensure the dynamic security file is owned by the mosquitto group and is group-writable (restricted to owner and group only)
if [[ -n $SUDO ]]; then
    $SUDO chgrp $GROUP $DYN_FILE || true
    $SUDO chmod 0660 $DYN_FILE || true
fi

if [[ ! -f $PASS_FILE ]]; then
    echo Creating $PASS_FILE
    $SUDO touch $PASS_FILE
    $SUDO mosquitto_passwd -b ${PASS_FILE} ${AUTH_USER} ${AUTH_PASS}
fi

# Ensure the passwd file is owned by the mosquitto user and is strictly private (0600)
if [[ -n $SUDO ]]; then
    $SUDO chown mosquitto:mosquitto $PASS_FILE || true
    $SUDO chmod 0600 $PASS_FILE || true
fi

if [[ ${UDMI_NO_SUDO:-false} == true ]]; then
    # Raw mode for running without sudo
    mosquitto -c $ETC_DIR/mosquitto.conf > $MOSQUITTO_LOG 2>&1 &
    MOSQUITTO_PID=$!
    echo Waiting 10s for background mosquitto to start...
    sleep 10
    [[ -d /proc/$MOSQUITTO_PID ]] || (cat $MOSQUITTO_LOG && fail starting mosquitto)
    echo Completed mosquitto startup.
elif command -v systemctl >/dev/null 2>&1; then
    sudo systemctl restart mosquitto
else
    # Raw mode for running (e.g.) in a docker container
    (cd / && mosquitto -c $ETC_DIR/mosquitto.conf) > $MOSQUITTO_LOG 2>&1 &
    MOSQUITTO_PID=$!
    echo Waiting 10s for background mosquitto to start...
    sleep 10
    [[ -d /proc/$MOSQUITTO_PID ]] || (cat $MOSQUITTO_LOG && fail starting mosquitto)
    echo Completed mosquitto startup.
fi

$MOSQUITTO_CTRL createRole service || true
$MOSQUITTO_CTRL addRoleACL service subscribePattern '/r/+/d/+/#' allow || true
$MOSQUITTO_CTRL addRoleACL service publishClientSend '/r/+/d/+/#' allow || true
$MOSQUITTO_CTRL addRoleACL service subscribePattern '/uufi/#' allow || true
$MOSQUITTO_CTRL addRoleACL service publishClientSend '/uufi/#' allow || true
$MOSQUITTO_CTRL addClientRole $AUTH_USER service || true

$MOSQUITTO_CTRL createRole uufi || true
$MOSQUITTO_CTRL addRoleACL uufi subscribePattern '/uufi/#' allow || true
$MOSQUITTO_CTRL addRoleACL uufi publishClientSend '/uufi/#' allow || true

clients=$($MOSQUITTO_CTRL listClients)
if [[ $clients =~ ${AUTH_USER} ]]; then
    echo Found expected client $AUTH_USER
else
    fail Improper client: $clients
fi
