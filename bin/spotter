#!/bin/bash
# Start script for UDMI Spotter Agent

set -eo pipefail

# Find workspace directory
SCRIPT_DIR=$(dirname "$(realpath "$0")")
WORKSPACE_DIR=$(realpath "${SCRIPT_DIR}/..")

# Default values
MODE="local"
CONFIG_PATH=""
CONFIG_DIR=""

function show_help() {
    echo "Usage: $0 SITE_PATH PROJECT_SPEC DEVICE_ID [options]"
    echo "   or: $0 [options]"
    echo ""
    echo "Positional Arguments (Pubber-style):"
    echo "  SITE_PATH                  Path to the site model directory (e.g. sites/udmi_site_model)"
    echo "  PROJECT_SPEC               Project specification string (e.g. //mqtt/localhost:18883)"
    echo "  DEVICE_ID                  Target device ID (e.g. AHU-1)"
    echo ""
    echo "Options:"
    echo "  --mode <container|local>   Specify how to run the Spotter Agent (default: local)"
    echo "  --config <path>            Path to spotter_config.json"
    echo "  --config_dir <path>        Directory containing config and certificates (optional)"
    echo "  -h, --help                 Show this help message"
}

# Check for positional pubber-style arguments
if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
    if [[ $# -lt 3 ]]; then
        echo "Error: Positional usage requires SITE_PATH, PROJECT_SPEC, and DEVICE_ID."
        show_help
        exit 1
    fi
    SITE_PATH=$(realpath "$1")
    PROJECT_SPEC="$2"
    DEVICE_ID="$3"
    shift 3
    
    # Parse remaining options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mode)
                MODE="$2"
                shift 2
                ;;
            --config_dir)
                CONFIG_DIR="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                echo "Error: Unknown option $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    # Construct config dynamically
    echo "Constructing configuration dynamically from site model..."
    
    if [[ ! -d "${SITE_PATH}" ]]; then
        echo "Error: Site path directory not found: ${SITE_PATH}"
        exit 1
    fi
    
    SITE_CONFIG="${SITE_PATH}/cloud_iot_config.json"
    if [[ ! -f "${SITE_CONFIG}" ]]; then
        echo "Error: cloud_iot_config.json not found inside site path: ${SITE_CONFIG}"
        exit 1
    fi
    
    REGISTRY_ID=$(jq -r .registry_id "${SITE_CONFIG}")
    
    # Parse PROJECT_SPEC
    # Format of PROJECT_SPEC is {//PROVIDER/}PROJECT[@BROKER]
    # e.g. //mqtt/localhost:18883
    # Extract port and host
    PORT=18883
    HOST="localhost"
    
    if [[ "${PROJECT_SPEC}" =~ localhost:([0-9]+) ]]; then
        PORT="${BASH_REMATCH[1]}"
        HOST="localhost"
    elif [[ "${PROJECT_SPEC}" =~ :([0-9]+) ]]; then
        PORT="${BASH_REMATCH[1]}"
    fi
    
    # Check/Create device folder in site model if not present
    DEVICE_DIR="${SITE_PATH}/devices/${DEVICE_ID}"
    if [[ ! -d "${DEVICE_DIR}" ]]; then
        echo "Creating device folder: ${DEVICE_DIR}..."
        mkdir -p "${DEVICE_DIR}"
        cat <<EOF > "${DEVICE_DIR}/metadata.json"
{
  "cloud": {
    "auth_type": "RS256_X509"
  },
  "system": {
    "location": {
      "site": "spotter-testing"
    }
  }
}
EOF
    fi
    
    # Run mosquctl_device to ensure keys exist and are registered on broker
    echo "Ensuring keys are generated and registered on broker..."
    # We call it with MQTT_PORT so that it knows which port to connect to if broker is active
    MQTT_PORT="${PORT}" "${WORKSPACE_DIR}/bin/mosquctl_device" "${SITE_PATH}" "${DEVICE_ID}" >/dev/null 2>&1 || true
    
    # Resolve the generated key file paths
    PKCS8_FILE="${DEVICE_DIR}/rsa_private.pkcs8"
    if [[ ! -f "${PKCS8_FILE}" ]]; then
        PKCS8_FILE="${DEVICE_DIR}/ec_private.pkcs8"
    fi
    
    KEY_FILE="${DEVICE_DIR}/rsa_private.pem"
    if [[ ! -f "${KEY_FILE}" ]]; then
        KEY_FILE="${DEVICE_DIR}/ec_private.pem"
    fi
    
    CA_FILE="${SITE_PATH}/reflector/ca.crt"
    
    CERT_FILE="${DEVICE_DIR}/rsa_private.crt"
    if [[ ! -f "${CERT_FILE}" ]]; then
        CERT_FILE="${DEVICE_DIR}/ec_private.crt"
    fi
    
    if [[ ! -f "${KEY_FILE}" ]]; then
        echo "Error: Private key file not found: ${KEY_FILE}"
        exit 1
    fi
    
    # Re-register the client without client ID constraint to allow Spotter Agent and legacy node to coexist
    DEV_USER="/r/${REGISTRY_ID}/d/${DEVICE_ID}"
    DEV_PASS=$(sha256sum < "${PKCS8_FILE}" | cut -c1-8)
    
    # Source mosquitto_ctrl.sh to get MOSQUITTO_CTRL command definition
    export MQTT_PORT="${PORT}"
    export UDMI_ROOT="${WORKSPACE_DIR}"
    # Temporarily turn off set -u to avoid mosquitto_ctrl.sh unbound variable errors
    set +u
    source "${WORKSPACE_DIR}/etc/mosquitto_ctrl.sh"
    set -u
    
    echo "Updating broker dynsec rules to allow multiple client IDs for ${DEVICE_ID}..."
    $MOSQUITTO_CTRL deleteClient $DEV_USER >/dev/null 2>&1 || true
    $MOSQUITTO_CTRL createClient $DEV_USER -p $DEV_PASS >/dev/null 2>&1 || true
    $MOSQUITTO_CTRL addClientRole $DEV_USER service >/dev/null 2>&1 || true
    
    # Create a temporary runtime config file
    CONFIG_PATH="${WORKSPACE_DIR}/out/spotter_runtime_config.json"
    mkdir -p "$(dirname "${CONFIG_PATH}")"
    
    cat <<EOF > "${CONFIG_PATH}"
{
  "log_level": "INFO",
  "mqtt": {
    "device_id": "${DEVICE_ID}",
    "registry_id": "${REGISTRY_ID}",
    "host": "${HOST}",
    "port": ${PORT},
    "authentication_mechanism": "udmi_local",
    "region": "us-central1",
    "project_id": "my-project",
    "key_file": "${KEY_FILE}",
    "cert_file": "${CERT_FILE}",
    "ca_file": "${CA_FILE}",
    "algorithm": "RS256"
  },
  "bacnet": {
    "ip": "127.0.0.1"
  }
}
EOF
    echo "Dynamic configuration generated: ${CONFIG_PATH}"

else
    # Parse command line options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mode)
                MODE="$2"
                shift 2
                ;;
            --config)
                CONFIG_PATH="$2"
                shift 2
                ;;
            --config_dir)
                CONFIG_DIR="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                echo "Error: Unknown option $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    if [[ -z "${CONFIG_PATH}" ]]; then
        echo "Error: Either positional arguments (SITE_PATH PROJECT_SPEC DEVICE_ID) or --config <path> must be specified."
        show_help
        exit 1
    fi
fi

CONFIG_PATH=$(realpath "${CONFIG_PATH}")
if [[ ! -f "${CONFIG_PATH}" ]]; then
    echo "Error: Config file not found at ${CONFIG_PATH}"
    exit 1
fi

if [[ -z "${CONFIG_DIR}" ]]; then
    CONFIG_DIR=$(dirname "${CONFIG_PATH}")
fi
CONFIG_DIR=$(realpath "${CONFIG_DIR}")

# Change working directory to config directory to ensure relative paths in config resolve correctly
cd "${CONFIG_DIR}"

# Build path to venv
VENV_DIR="${WORKSPACE_DIR}/venv"

if [[ "${MODE}" == "container" ]]; then
    echo "=== Running Spotter Agent in CONTAINER mode ==="
    
    # 1. Verify Docker daemon is running
    if ! docker info >/dev/null 2>&1; then
        echo "Error: Docker daemon is not running or accessible."
        exit 1
    fi
    
    # 2. Build Docker container
    echo "Building udmi-spotter:latest image..."
    docker build -t udmi-spotter:latest -f "${WORKSPACE_DIR}/edge/spotter/container/Dockerfile" "${WORKSPACE_DIR}"
    
    # 3. Ensure logs directory exists in host config dir
    mkdir -p "${CONFIG_DIR}/logs"
    
    # 4. Run the container
    echo "Starting Spotter Agent container..."
    docker run -it --rm \
        --name udmi-spotter-agent \
        -v "${CONFIG_DIR}:/config_dir" \
        -v "${CONFIG_DIR}/logs:/var/log/spotter" \
        udmi-spotter:latest \
        --config_file "/config_dir/$(basename "${CONFIG_PATH}")"

elif [[ "${MODE}" == "local" ]]; then
    echo "=== Running Spotter Agent in LOCAL mode ==="
    
    # 1. Setup Spotter virtual environment
    if [[ ! -d "${VENV_DIR}" ]]; then
        echo "Creating Spotter virtual environment at ${VENV_DIR}..."
        python3 -m venv "${VENV_DIR}"
    fi
    
    echo "Installing/updating Spotter dependencies..."
    (
        cd "${WORKSPACE_DIR}"
        "${VENV_DIR}/bin/pip" install --disable-pip-version-check --extra-index-url https://pypi.org/simple -q -e clientlib/python
        "${VENV_DIR}/bin/pip" install --disable-pip-version-check --extra-index-url https://pypi.org/simple -q -r edge/spotter/requirements.txt
    )
    
    # 2. Setup Legacy Discovery Node virtual environment
    LEGACY_VENV_DIR="${WORKSPACE_DIR}/misc/discoverynode/venv"
    if [[ ! -d "${LEGACY_VENV_DIR}" ]]; then
        echo "Creating Legacy Discovery Node virtual environment at ${LEGACY_VENV_DIR}..."
        python3 -m venv "${LEGACY_VENV_DIR}"
    fi
    
    echo "Installing/updating Legacy Discovery Node dependencies..."
    (
        cd "${WORKSPACE_DIR}/misc/discoverynode/src"
        "${LEGACY_VENV_DIR}/bin/pip" install --disable-pip-version-check --extra-index-url https://pypi.org/simple -q -r requirements.txt
    )
    
    # 3. Export path overrides for supervisor
    export LEGACY_PATH="${WORKSPACE_DIR}/misc/discoverynode/src/main.py"
    export SPOTTER_PATH="${WORKSPACE_DIR}/edge/spotter/src/agent.py"
    export LEGACY_VENV="${LEGACY_VENV_DIR}/bin/python3"
    export SPOTTER_VENV="${VENV_DIR}/bin/python3"
    export PYTHONPATH="${WORKSPACE_DIR}/clientlib/python/src:${WORKSPACE_DIR}/edge/spotter/src"
    
    # Ensure logs directories exist locally
    mkdir -p "${WORKSPACE_DIR}/out/logs/discovery_node"
    mkdir -p "${WORKSPACE_DIR}/out/logs/spotter"
    
    # 4. Run supervisor
    echo "Starting supervised local services..."
    exec "${WORKSPACE_DIR}/edge/spotter/container/supervisor.sh" --config_file "${CONFIG_PATH}"

else
    echo "Error: Invalid mode '${MODE}'. Allowed modes: container, local."
    show_help
    exit 1
fi
