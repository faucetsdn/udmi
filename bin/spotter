#!/bin/bash
# Start script for UDMI Spotter Agent

set -eo pipefail

# Find workspace directory
SCRIPT_DIR=$(dirname "$(realpath "$0")")
WORKSPACE_DIR=$(realpath "${SCRIPT_DIR}/..")

# Default values
MODE="local"
CONFIG_PATH=""
SERIAL_NO=""

function show_help() {
    echo "Usage:"
    echo "  1. From Site Model (Local Dev / Sequencer):"
    echo "     $0 SITE_PATH PROJECT_SPEC DEVICE_ID [SPOTTER_DEVICE_ID] [SERIAL_NO] [options]"
    echo ""
    echo "  2. From Configuration File (Production / Deployed Device):"
    echo "     $0 CONFIG_FILE [SERIAL_NO] [options]"
    echo ""
    echo "Examples:"
    echo "  $0 sites/udmi_site_model //mqtt/localhost AHU-1 AHU-1-spotter"
    echo "  $0 sites/udmi_site_model //mqtt/localhost AHU-1 AHU-1-spotter 1234"
    echo "  $0 edge/spotter/spotter_config.json 1234 --mode container"
    echo ""
    echo "Arguments:"
    echo "  SITE_PATH                  Path to site model directory"
    echo "  PROJECT_SPEC               Project specification string (e.g. //mqtt/localhost:18883)"
    echo "  DEVICE_ID                  Target device ID (e.g. AHU-1)"
    echo "  SPOTTER_DEVICE_ID          Spotter agent device ID (default: DEVICE_ID-spotter)"
    echo "  CONFIG_FILE                Path to spotter_config.json file"
    echo "  SERIAL_NO                  Serial number for this Spotter instance (default: NA)"
    echo ""
    echo "Options:"
    echo "  --mode <container|local>   Specify how to run the Spotter Agent (default: local)"
    echo "  --config_dir <path>        Directory containing config and certificates (optional)"
    echo "  -h, --help                 Show this help message"
}

# Check for positional TARGET argument
if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
    if [[ -f "$1" ]]; then
        CONFIG_PATH=$(realpath "$1")
        shift
        if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
            SERIAL_NO="$1"
            shift
        fi
        
        # Parse remaining options
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --mode)
                    MODE="$2"
                    shift 2
                    ;;
                --config_dir)
                    CONFIG_DIR="$2"
                    shift 2
                    ;;
                -h|--help)
                    show_help
                    exit 0
                    ;;
                *)
                    echo "Error: Unknown option $1"
                    show_help
                    exit 1
                    ;;
            esac
        done
    elif [[ -d "$1" ]]; then
        if [[ $# -lt 3 ]]; then
            echo "Error: Site model directory target requires SITE_PATH, PROJECT_SPEC, and DEVICE_ID."
            show_help
            exit 1
        fi
        SITE_PATH=$(realpath "$1")
        PROJECT_SPEC="$2"
        DEVICE_ID="$3"
        shift 3

        SPOTTER_DEVICE_ID=""
        if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
            SPOTTER_DEVICE_ID="$1"
            shift
        fi

        if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
            SERIAL_NO="$1"
            shift
        fi
        
        # Parse remaining options
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --mode)
                    MODE="$2"
                    shift 2
                    ;;
                --config_dir)
                    CONFIG_DIR="$2"
                    shift 2
                    ;;
                -h|--help)
                    show_help
                    exit 0
                    ;;
                *)
                    echo "Error: Unknown option $1"
                    show_help
                    exit 1
                    ;;
            esac
        done
    else
        echo "Error: Specified target '$1' is neither a file nor a directory."
        show_help
        exit 1
    fi
    
    if [[ -n "${SITE_PATH:-}" ]]; then
        # Construct config dynamically
        echo "Constructing configuration dynamically from site model..."
        
        if [[ ! -d "${SITE_PATH}" ]]; then
            echo "Error: Site path directory not found: ${SITE_PATH}"
            exit 1
        fi
        
        SITE_CONFIG="${SITE_PATH}/cloud_iot_config.json"
        if [[ ! -f "${SITE_CONFIG}" ]]; then
            echo "Error: cloud_iot_config.json not found inside site path: ${SITE_CONFIG}"
            exit 1
        fi
        
        REGISTRY_BASE=$(jq -r .registry_id "${SITE_CONFIG}")
        CLOUD_REGION=$(jq -r .cloud_region "${SITE_CONFIG}" 2>/dev/null || true)
        [[ "${CLOUD_REGION}" == "null" || -z "${CLOUD_REGION}" ]] && CLOUD_REGION="us-central1"

        # Parse PROJECT_SPEC
        # Format: [//PROVIDER/]PROJECT_ID[/UDMI_NAMESPACE][@BROKER][:PORT]
        # e.g. //mqtt/localhost:18883, //gbos/bos-platform-dev/faucetsdn, //clearblade/bos-platform-dev/my-namespace
        RAW_SPEC="${PROJECT_SPEC#//}"
        IOT_PROVIDER=""
        UDMI_PREFIX=""
        PORT=""
        HOST=""
        BROKER_SPEC=""
        AUTH_MECHANISM="udmi_local"

        if [[ "${PROJECT_SPEC}" =~ ^// ]]; then
            IOT_PROVIDER="${RAW_SPEC%%/*}"
            SPEC_NO_PROVIDER="${RAW_SPEC#*/}"
        else
            IOT_PROVIDER="mqtt"
            SPEC_NO_PROVIDER="${RAW_SPEC}"
        fi

        # Extract target host/broker if @ is present
        if [[ "${SPEC_NO_PROVIDER}" =~ @ ]]; then
            BROKER_SPEC="${SPEC_NO_PROVIDER#*@}"
            SPEC_TARGET="${SPEC_NO_PROVIDER%@*}"
        else
            BROKER_SPEC=""
            SPEC_TARGET="${SPEC_NO_PROVIDER}"
        fi

        # Extract UDMI namespace if present (e.g. bos-platform-dev/faucetsdn or bos-platform-dev+heykhyati)
        if [[ "${SPEC_TARGET}" == *"/"* ]]; then
            PROJECT_ID="${SPEC_TARGET%%/*}"
            UDMI_NAMESPACE="${SPEC_TARGET#*/}"
            if [[ -n "${UDMI_NAMESPACE}" ]]; then
                UDMI_PREFIX="${UDMI_NAMESPACE}~"
            fi
        elif [[ "${SPEC_TARGET}" == *"+"* ]]; then
            PROJECT_ID="${SPEC_TARGET%%+*}"
            UDMI_NAMESPACE="${SPEC_TARGET#*+}"
            if [[ -n "${UDMI_NAMESPACE}" ]]; then
                UDMI_PREFIX="${UDMI_NAMESPACE}~"
            fi
        else
            PROJECT_ID="${SPEC_TARGET}"
        fi

        REGISTRY_ID="${UDMI_PREFIX}${REGISTRY_BASE}"

        # Determine Host, Port, and Auth Mechanism based on IOT_PROVIDER
        if [[ "${IOT_PROVIDER}" == "clearblade" ]]; then
            HOST="${CLOUD_REGION}-mqtt.clearblade.com"
            PORT=8883
            AUTH_MECHANISM="jwt_gcp"
        elif [[ "${IOT_PROVIDER}" == "gbos" ]]; then
            HOST="mqtt.bos.goog"
            PORT=8883
            AUTH_MECHANISM="jwt_gcp"
        elif [[ "${IOT_PROVIDER}" == "gcp" || "${IOT_PROVIDER}" == "gref" ]]; then
            HOST="mqtt.googleapis.com"
            PORT=8883
            AUTH_MECHANISM="jwt_gcp"
        else # default: mqtt
            AUTH_MECHANISM="udmi_local"
            PORT=18883
            HOST="${PROJECT_ID}"
        fi

        # Override host/port if explicit @BROKER or port specified
        if [[ -n "${BROKER_SPEC}" ]]; then
            if [[ "${BROKER_SPEC}" =~ :([0-9]+) ]]; then
                PORT="${BASH_REMATCH[1]}"
                HOST="${BROKER_SPEC%:*}"
            else
                HOST="${BROKER_SPEC}"
            fi
        elif [[ "${PROJECT_ID}" =~ :([0-9]+) ]]; then
            PORT="${BASH_REMATCH[1]}"
            PROJECT_ID="${PROJECT_ID%:*}"
            if [[ "${IOT_PROVIDER}" == "mqtt" ]]; then
                HOST="localhost"
            fi
        fi

        # Fallback to site_config if PROJECT_ID is empty
        if [[ -z "${PROJECT_ID}" || "${PROJECT_ID}" == "localhost" && "${IOT_PROVIDER}" != "mqtt" ]]; then
            PROJECT_ID=$(jq -r .project_id "${SITE_CONFIG}" 2>/dev/null || true)
            [[ "${PROJECT_ID}" == "null" || -z "${PROJECT_ID}" ]] && PROJECT_ID="my-project"
        fi
        
        SPOTTER_DEVICE_ID="${SPOTTER_DEVICE_ID:-${DEVICE_ID}-spotter}"

        # Verify device folder exists in site model
        DEVICE_DIR="${SITE_PATH}/devices/${DEVICE_ID}"
        if [[ ! -d "${DEVICE_DIR}" ]]; then
            echo "Error: Device directory does not exist: ${DEVICE_DIR}"
            exit 1
        fi
        
        # Resolve key and certificate paths from site model device directory
        KEY_FILE="${DEVICE_DIR}/rsa_private.pem"
        if [[ ! -f "${KEY_FILE}" ]]; then
            KEY_FILE="${DEVICE_DIR}/ec_private.pem"
        fi
        
        CERT_FILE="${DEVICE_DIR}/rsa_private.crt"
        if [[ ! -f "${CERT_FILE}" ]]; then
            CERT_FILE="${DEVICE_DIR}/ec_private.crt"
        fi
        
        if [[ ! -f "${KEY_FILE}" ]]; then
            echo "Error: Private key file not found: ${KEY_FILE}"
            exit 1
        fi

        # Resolve spotter device key file (falling back to DEVICE_DIR if spotter device dir doesn't exist)
        SPOTTER_DEVICE_DIR="${SITE_PATH}/devices/${SPOTTER_DEVICE_ID}"
        SPOTTER_KEY_FILE="${KEY_FILE}"
        SPOTTER_CERT_FILE="${CERT_FILE}"
        if [[ -d "${SPOTTER_DEVICE_DIR}" ]]; then
            [[ -f "${SPOTTER_DEVICE_DIR}/rsa_private.pem" ]] && SPOTTER_KEY_FILE="${SPOTTER_DEVICE_DIR}/rsa_private.pem"
            [[ -f "${SPOTTER_DEVICE_DIR}/ec_private.pem" ]] && SPOTTER_KEY_FILE="${SPOTTER_DEVICE_DIR}/ec_private.pem"
            [[ -f "${SPOTTER_DEVICE_DIR}/rsa_private.crt" ]] && SPOTTER_CERT_FILE="${SPOTTER_DEVICE_DIR}/rsa_private.crt"
            [[ -f "${SPOTTER_DEVICE_DIR}/ec_private.crt" ]] && SPOTTER_CERT_FILE="${SPOTTER_DEVICE_DIR}/ec_private.crt"
        fi

        # CA_FILE is only for local mTLS reflector. Cloud providers use system Root CAs.
        CA_JSON="null"
        if [[ "${IOT_PROVIDER}" == "mqtt" ]]; then
            CA_JSON="\"${SITE_PATH}/reflector/ca.crt\""
        fi
        
        # Create a temporary runtime config file
        CONFIG_PATH="${WORKSPACE_DIR}/out/spotter_runtime_config.json"
        mkdir -p "$(dirname "${CONFIG_PATH}")"
        
        cat <<EOF > "${CONFIG_PATH}"
{
  "log_level": "INFO",
  "mqtt": {
    "device_id": "${DEVICE_ID}",
    "spotter_device_id": "${SPOTTER_DEVICE_ID}",
    "registry_id": "${REGISTRY_ID}",
    "host": "${HOST}",
    "port": ${PORT},
    "authentication_mechanism": "${AUTH_MECHANISM}",
    "region": "${CLOUD_REGION}",
    "project_id": "${PROJECT_ID}",
    "key_file": "${SPOTTER_KEY_FILE}",
    "cert_file": "${SPOTTER_CERT_FILE}",
    "ca_file": ${CA_JSON},
    "algorithm": "RS256"
  },
  "bacnet": {
    "ip": "127.0.0.1"
  }
}
EOF
        echo "Dynamic configuration generated: ${CONFIG_PATH}"
    fi

else
    # Parse command line options when no positional argument is provided
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mode)
                MODE="$2"
                shift 2
                ;;
            --config)
                CONFIG_PATH="$2"
                shift 2
                ;;
            --config_dir)
                CONFIG_DIR="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                echo "Error: Unknown option $1"
                show_help
                exit 1
                ;;
        esac
    done
fi

if [[ -z "${SERIAL_NO}" ]]; then
    SERIAL_NO="NA"
fi

if [[ -z "${CONFIG_PATH:-}" ]]; then
    if [[ -f "${WORKSPACE_DIR}/edge/spotter/spotter_config.json" ]]; then
        CONFIG_PATH="${WORKSPACE_DIR}/edge/spotter/spotter_config.json"
    elif [[ -f "spotter_config.json" ]]; then
        CONFIG_PATH="spotter_config.json"
    else
        echo "Error: Target configuration file or site path not specified, and default spotter_config.json not found."
        show_help
        exit 1
    fi
fi

CONFIG_PATH=$(realpath "${CONFIG_PATH}")
if [[ ! -f "${CONFIG_PATH}" ]]; then
    echo "Error: Config file not found at ${CONFIG_PATH}"
    exit 1
fi

if [[ -z "${CONFIG_DIR}" ]]; then
    CONFIG_DIR=$(dirname "${CONFIG_PATH}")
fi
CONFIG_DIR=$(realpath "${CONFIG_DIR}")

# Change working directory to config directory to ensure relative paths in config resolve correctly
cd "${CONFIG_DIR}"

# Build path to venv
VENV_DIR="${WORKSPACE_DIR}/venv"

if [[ "${MODE}" == "container" ]]; then
    CONTAINER_NAME="udmi-spotter-agent-${SERIAL_NO}"
    echo "=== Running Spotter Agent (${SERIAL_NO}) in CONTAINER mode ==="
    
    # 1. Verify Docker daemon is running
    if ! docker info >/dev/null 2>&1; then
        echo "Error: Docker daemon is not running or accessible."
        exit 1
    fi
    
    # 2. Build Docker container
    echo "Building udmi-spotter:latest image..."
    docker build -t udmi-spotter:latest -f "${WORKSPACE_DIR}/edge/spotter/container/Dockerfile" "${WORKSPACE_DIR}"
    
    # 3. Ensure logs directory exists in host config dir
    mkdir -p "${CONFIG_DIR}/logs"
    
    # 4. Run the container
    echo "Starting Spotter Agent container '${CONTAINER_NAME}'..."
    docker run -it --rm \
        --name "${CONTAINER_NAME}" \
        -v "${CONFIG_DIR}:/config_dir" \
        -v "${CONFIG_DIR}/logs:/var/log/spotter" \
        udmi-spotter:latest \
        --config_file "/config_dir/$(basename "${CONFIG_PATH}")" \
        --serial_no "${SERIAL_NO}"

elif [[ "${MODE}" == "local" ]]; then
    echo "=== Running Spotter Agent (${SERIAL_NO}) in LOCAL mode ==="
    
    # 1. Setup Spotter virtual environment
    if [[ ! -d "${VENV_DIR}" ]]; then
        echo "Creating Spotter virtual environment at ${VENV_DIR}..."
        python3 -m venv "${VENV_DIR}"
    fi
    
    echo "Installing/updating Spotter dependencies..."
    (
        cd "${WORKSPACE_DIR}"
        "${VENV_DIR}/bin/pip" install --disable-pip-version-check --extra-index-url https://pypi.org/simple -q -e clientlib/python
        "${VENV_DIR}/bin/pip" install --disable-pip-version-check --extra-index-url https://pypi.org/simple -q -r edge/spotter/requirements.txt
    )
    
    # 2. Setup Legacy Discovery Node virtual environment
    LEGACY_VENV_DIR="${WORKSPACE_DIR}/misc/discoverynode/venv"
    if [[ ! -d "${LEGACY_VENV_DIR}" ]]; then
        echo "Creating Legacy Discovery Node virtual environment at ${LEGACY_VENV_DIR}..."
        python3 -m venv "${LEGACY_VENV_DIR}"
    fi
    
    echo "Installing/updating Legacy Discovery Node dependencies..."
    (
        cd "${WORKSPACE_DIR}/misc/discoverynode/src"
        "${LEGACY_VENV_DIR}/bin/pip" install --disable-pip-version-check --extra-index-url https://pypi.org/simple -q -r requirements.txt
    )
    
    # 3. Export path overrides for supervisor
    export LEGACY_PATH="${WORKSPACE_DIR}/misc/discoverynode/src/main.py"
    export SPOTTER_PATH="${WORKSPACE_DIR}/edge/spotter/src/agent.py"
    export LEGACY_VENV="${LEGACY_VENV_DIR}/bin/python3"
    export SPOTTER_VENV="${VENV_DIR}/bin/python3"
    export PYTHONPATH="${WORKSPACE_DIR}/clientlib/python/src:${WORKSPACE_DIR}/edge/spotter/src"
    
    # Ensure logs directories exist locally
    mkdir -p "${WORKSPACE_DIR}/out/logs/discovery_node"
    mkdir -p "${WORKSPACE_DIR}/out/logs/spotter"
    
    # 4. Run supervisor
    echo "Starting supervised local services for Serial No '${SERIAL_NO}'..."
    exec "${WORKSPACE_DIR}/edge/spotter/container/supervisor.sh" --config_file "${CONFIG_PATH}" --serial_no "${SERIAL_NO}"

else
    echo "Error: Invalid mode '${MODE}'. Allowed modes: container, local."
    show_help
    exit 1
fi
