#!/bin/bash -e

UDMI_ROOT=$(dirname $0)/..
source $UDMI_ROOT/etc/shell_common.sh
source $UDMI_ROOT/etc/mosquitto_ctrl.sh

SUDO=sudo
if [[ ${UDMI_NO_SUDO:-false} == true ]]; then
    SUDO=""
fi

if [[ -n $SUDO ]]; then
    # Something to just trigger password entry early on in the process
    $SUDO touch /dev/null
fi

UDMIS_PID_FILE=var/udmis.pid
if [[ -f $UDMIS_PID_FILE ]]; then
    OLD_PID=$(cat $UDMIS_PID_FILE)
    if ps -p $OLD_PID > /dev/null 2>&1; then
        echo "Killing old udmis process $OLD_PID from local PID file..."
        $SUDO kill $OLD_PID || true
        sleep 2
    fi
else
    # Fallback only if no local PID file and not in NO_SUDO mode
    if [[ ${UDMI_NO_SUDO:-false} != true ]]; then
        OLD_PID=$(ps ax | fgrep java | fgrep udmis | awk '{print $1}') || true
        if [[ -n $OLD_PID ]]; then
            echo "Killing old udmis process $OLD_PID..."
            $SUDO kill $OLD_PID || true
            sleep 2
        fi
    fi
fi

if [[ -f /.dockerenv || -n ${UDMI_CONTAINER:-} ]]; then
    POD_READY=${UDMI_POD_READY:-/tmp/pod_ready.txt}
else
    POD_READY=${UDMI_POD_READY:-var/pod_ready.txt}
fi
export UDMI_POD_READY=$(realpath $POD_READY)
rm -f $POD_READY

if [[ ${1:-} == stop ]]; then
    exit 0
fi

$UDMI_ROOT/bin/container udmis prep --no-check || true

LOGFILE=out/udmis.log
mkdir -p out
date >> $LOGFILE

export ETCD_CLUSTER=127.0.0.1
export SSL_SECRETS_DIR=$(realpath $CERT_DIR)
if [[ ${UDMI_NO_SUDO:-false} == true ]]; then
    export MOSQUITTO_LOG_PATH=$(realpath $ETC_DIR/log/mosquitto.log)
else
    export MOSQUITTO_LOG_PATH=/var/log/mosquitto/mosquitto.log
fi

if [[ -f /.dockerenv || -n ${UDMI_CONTAINER:-} ]] && [[ -f /root/bin/run ]]; then
    UDMIS_DIR=/root
else
    UDMIS_DIR=$UDMI_ROOT/udmis
fi

# Default config preprocessing
if [[ -z ${UDMIS_CONFIG:-} ]]; then
    mkdir -p var
    if [[ -f /root/var/local_pod.json ]]; then
        SOURCE_POD_CONFIG=/root/var/local_pod.json
        INCLUDE_PATH=/root/var/prod_pod.json
    else
        SOURCE_POD_CONFIG=$UDMIS_DIR/etc/local_pod.json
        INCLUDE_PATH="$UDMI_ROOT/udmis/etc/prod_pod.json"
    fi
    ABS_CERT_DIR=$(realpath $CERT_DIR)
    jq '.include = "'"$INCLUDE_PATH"'" |
        .flow_defaults.ca_file = "'"$ABS_CERT_DIR/ca.crt"'" |
        .flow_defaults.cert_file = "'"$ABS_CERT_DIR/rsa_private.crt"'" |
        .flow_defaults.key_file = "'"$ABS_CERT_DIR/rsa_private.pem"'" |
        .flow_defaults.port = '"${MQTT_PORT:-8883}"' |
        .iot_access.implicit.project_id = "http://${ETCD_CLUSTER}:'"${ETCD_PORT:-2379}"'" |
        .iot_access.implicit.endpoint.port = '"${MQTT_PORT:-8883}"' |
        .iot_access.implicit.endpoint.ca_file = "'"$ABS_CERT_DIR/ca.crt"'" |
        .iot_access.implicit.endpoint.cert_file = "'"$ABS_CERT_DIR/rsa_private.crt"'" |
        .iot_access.implicit.endpoint.key_file = "'"$ABS_CERT_DIR/rsa_private.pem"'" |
        .iot_data.database.project_id = "http://${ETCD_CLUSTER}:'"${ETCD_PORT:-2379}"'"' \
        $SOURCE_POD_CONFIG | sponge var/local_pod.json
    UDMIS_CONFIG=var/local_pod.json
fi

echo Using UDMIS_CONFIG $UDMIS_CONFIG

nohup $UDMIS_DIR/bin/run $UDMIS_CONFIG >> $LOGFILE 2>&1 &

PID=$!
echo $PID > $UDMIS_PID_FILE

WAITING=30
for i in `seq 1 $WAITING`; do
    if [[ -f $POD_READY || ! -d /proc/$PID ]]; then
        break
    fi
    echo Waiting for udmis startup $((WAITING - i))...
    sleep 1
done

echo ::::::::: tail $LOGFILE
tail -n 30 $LOGFILE

if [[ ! -f $POD_READY ]]; then
    echo "=== DIAGNOSTIC LOGS FOR UDMIS STARTUP FAILURE ==="
    echo "Host working directory: $PWD"
    echo "Process $PID status:"
    ps -p $PID || echo "Process $PID not running"
    echo "Last 100 lines of $LOGFILE:"
    tail -n 100 $LOGFILE || true
    echo "var/ directory contents:"
    ls -la var || true
    echo "=== END DIAGNOSTIC LOGS ==="
fi

[[ -f $POD_READY ]] || fail pod_ready.txt not found.

echo udmis running in the background, pid $PID log in $(realpath $LOGFILE)
