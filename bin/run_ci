#!/bin/bash
# Wrapper script to run udmi-ci container locally, bypassing permission issues on strict umask hosts.

set -e

UDMI_ROOT=$(realpath $(dirname $0)/..)
cd "$UDMI_ROOT"

# Ensure tmp/ directory exists
mkdir -p tmp

TAR_FILE="tmp/udmi_src.tar"

# Clean up tarball on exit
trap 'rm -f "$UDMI_ROOT/$TAR_FILE"' EXIT

echo "Creating workspace tarball: $TAR_FILE..."
# Archive source, excluding large/generated/temp directories to make it fast
tar --exclude='./.gradle' \
    --exclude='./build' \
    --exclude='./out' \
    --exclude='./.gemini' \
    --exclude='./validator/build' \
    --exclude='./udmis/build' \
    --exclude='./pubber/build' \
    --exclude='./services/build' \
    --exclude='./venv' \
    --exclude='./tmp' \
    --exclude='./sites' \
    -cf "$TAR_FILE" .

# Make the tarball readable by the docker user (UID 1000)
chmod 644 "$TAR_FILE"

echo "Running udmi-ci container..."
# Run docker container, mounting the tarball
# We use -t for interactive TTY when run from a terminal
TTY_FLAG=""
[ -t 0 ] && TTY_FLAG="-t"

docker run -i $TTY_FLAG \
  -v "$UDMI_ROOT/$TAR_FILE":/home/runner/udmi_src.tar \
  udmi-ci
