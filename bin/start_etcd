#!/bin/bash -e

IMAGE=quay.io/coreos/etcd:v3.5.13
BINDIR=""
for path in \
    "udmis/bin/etcd_bin" \
    "bin/etcd_bin" \
    "/root/bin/etcd_bin" \
    "/root/udmi/bin/etcd_bin" \
    "/tmp/etcd"; do
    if [[ -f "$path/etcd" ]]; then
        BINDIR="$path"
        break
    fi
done

if [[ -z $BINDIR ]]; then
    BINDIR=/tmp/etcd
fi
ETCD_LOG=out/etcd.log

echo pwd: $(pwd)
mkdir -p out

old_pid=$(ps ax | fgrep $BINDIR/etcd | fgrep listen | awk '{print $1}') || true
if [[ -n $old_pid ]]; then
    echo Killing existing etcd pid $old_pid...
    kill $old_pid
fi

if [[ ! -f $BINDIR/etcd ]]; then
    udmis/bin/etcdctl version || ../bin/etcdctl version || $(dirname $0)/etcdctl version || true
fi

$BINDIR/etcd -version

rm -rf var/etcd
mkdir -p var/etcd

nohup $BINDIR/etcd -listen-client-urls=http://0.0.0.0:2379 \
             -advertise-client-urls=http://127.0.0.1:2379 \
             --data-dir var/etcd \
             > $ETCD_LOG 2>&1 &
ETCD_PID=$!

echo Waiting 10s for etcd to start, log in $ETCD_LOG
sleep 10
[[ -d /proc/$ETCD_PID ]] || (cat $ETCD_LOG && echo error starting etcd && false)

echo Completed etcd startup.
