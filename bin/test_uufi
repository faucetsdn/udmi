#!/bin/bash -e

# UUFI Integration Test Script
# This script acts as a UUFI client to validate a running UUFI service.

UDMI_ROOT=$(dirname $0)/..
cd ${UDMI_ROOT}
source etc/shell_common.sh

HOST=${1:-localhost}
PORT=${2:-8883}
USER=${3:-rocket}
PASS=${4:-monkey}
CLIENT_ID="uufi-test-client"
SITE_MODEL=${5:-sites/uufi_site_model}
TXN_ID="TXN-$(date +%s)"

echo "Starting UUFI Integration Test against $HOST:$PORT..."

# Wait for the CA cert to be generated by the background setup process
CA_CERT="$SITE_MODEL/reflector/ca.crt"
echo "Waiting for non-empty CA certificate $CA_CERT..."
TIMEOUT=60
while [[ (! -f $CA_CERT || ! -s $CA_CERT) && $TIMEOUT -gt 0 ]]; do
    sleep 1
    TIMEOUT=$((TIMEOUT - 1))
done

if [[ ! -s $CA_CERT ]]; then
    echo "Valid CA certificate not found after 60 seconds."
    exit 1
fi

# Connection parameters for mosquitto_pub/sub
MQTT_ARGS="-h $HOST -p $PORT -u $USER -P $PASS --cafile $CA_CERT --cert $SITE_MODEL/reflector/rsa_private.crt --key $SITE_MODEL/reflector/rsa_private.pem -i $CLIENT_ID --insecure"


# 1. Start a background subscriber to capture the handshake reply
# We use -F to ensure single-line JSON for robust parsing
REPLY_FILE=$(mktemp)
mosquitto_sub $MQTT_ARGS -t "/uufi/c/config/udmi" -F "%p" | while read -r line; do
    echo "$line" > "$REPLY_FILE"
    REPLY_TXN=$(jq -r .payload.reply.transaction_id < "$REPLY_FILE" 2>/dev/null)
    if [[ "$REPLY_TXN" == "$TXN_ID" ]]; then
        # Signal success to the parent process and exit the subscriber loop
        kill -USR1 $$ 2>/dev/null || true
        exit 0
    fi
done &
SUB_PID=$!

# Use USR1 signal to know when we got the right handshake
GOT_HANDSHAKE=0
trap "GOT_HANDSHAKE=1" USR1

# Give the subscriber a moment to connect
sleep 2

# 2. Publish the Step 1 Handshake State message
echo "Sending UUFI handshake Step 1 (State Declaration)... (txn: $TXN_ID)"
HANDSHAKE_STATE="{\"version\":\"1.5.2\",\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"setup\":{\"functions_ver\":9,\"transaction_id\":\"$TXN_ID\",\"msg_source\":\"$CLIENT_ID\"}}"

mosquitto_pub $MQTT_ARGS -t "/uufi/c/state/udmi" -m "$HANDSHAKE_STATE"

# 3. Wait for the Step 2 Handshake Config message
echo "Waiting for UUFI handshake Step 2 (Config Confirmation)..."
TIMEOUT=30
while [ $GOT_HANDSHAKE -eq 0 ] && [ $TIMEOUT -gt 0 ]; do
    sleep 1
    TIMEOUT=$((TIMEOUT - 1))
done

if [ $GOT_HANDSHAKE -eq 0 ]; then
    echo "Timed out waiting for handshake reply (txn: $TXN_ID)"
    kill $SUB_PID 2>/dev/null || true
    exit 1
fi

kill $SUB_PID 2>/dev/null || true

# 4. Validate the handshake reply
echo "Validating handshake reply..."
REPLY_TXN=$(jq -r .payload.reply.transaction_id < "$REPLY_FILE")

if [[ "$REPLY_TXN" == "$TXN_ID" ]]; then
    echo "Handshake SUCCESS: Transaction ID matched ($TXN_ID)"
else
    echo "Handshake FAILED: Transaction ID mismatch. Expected $TXN_ID, got $REPLY_TXN"
    cat "$REPLY_FILE"
    exit 1
fi

# 5. Test message wrapping (Inbound)
echo "Sending UUFI-wrapped message..."
WRAPPED_MSG="{\"subType\":\"events\",\"subFolder\":\"pointset\",\"deviceId\":\"dev-1\",\"deviceRegistryId\":\"uufi-registry\",\"payload\":{\"version\":\"1.5.2\",\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"points\":{\"test_point\":{\"present_value\":123}}}}"
mosquitto_pub $MQTT_ARGS -t "/uufi/c/events/pointset" -m "$WRAPPED_MSG"

echo "UUFI Integration Test PASSED"
rm -f "$REPLY_FILE"
