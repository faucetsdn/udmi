#!/bin/bash -e

# UUFI Integration Test Script
# This script acts as a UUFI client to validate a running UUFI service.

UDMI_ROOT=$(dirname $0)/..
cd ${UDMI_ROOT}
source etc/shell_common.sh

HOST=${1:-localhost}
PORT=${2:-8883}
USER=${3:-rocket}
PASS=${4:-monkey}
CLIENT_ID="uufi-test-client"
TXN_ID="TXN-$(date +%s)"

echo "Starting UUFI Integration Test against $HOST:$PORT..."

# Wait for the CA cert to be generated by the background setup process
CA_CERT="sites/udmi_site_model/reflector/ca.crt"
echo "Waiting for CA certificate $CA_CERT..."
TIMEOUT=60
while [[ ! -f $CA_CERT && $TIMEOUT -gt 0 ]]; do
    sleep 1
    TIMEOUT=$((TIMEOUT - 1))
done

if [[ ! -f $CA_CERT ]]; then
    echo "CA certificate not found after 60 seconds."
    exit 1
fi

# Connection parameters for mosquitto_pub/sub
MQTT_ARGS="-h $HOST -p $PORT -u $USER -P $PASS --cafile $CA_CERT -i $CLIENT_ID --insecure"

# 1. Start a background subscriber to capture the handshake reply
REPLY_FILE=$(mktemp)
mosquitto_sub $MQTT_ARGS -t "/uufi/c/config/udmi" -C 1 > "$REPLY_FILE" &
SUB_PID=$!

# Give the subscriber a moment to connect
sleep 2

# 2. Publish the Step 1 Handshake State message
echo "Sending UUFI handshake Step 1 (State Declaration)..."
HANDSHAKE_STATE=$(cat <<EOF
{
  "version": "1.5.2",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "setup": {
    "functions_ver": 9,
    "transaction_id": "$TXN_ID",
    "msg_source": "$CLIENT_ID"
  }
}
EOF
)

mosquitto_pub $MQTT_ARGS -t "/uufi/c/state/udmi" -m "$HANDSHAKE_STATE"

# 3. Wait for the Step 2 Handshake Config message
echo "Waiting for UUFI handshake Step 2 (Config Confirmation)..."
# The subscriber will terminate after 1 message due to -C 1
timeout 15 wait $SUB_PID || { echo "Timed out waiting for handshake reply"; kill $SUB_PID || true; exit 1; }

# 4. Validate the handshake reply
echo "Validating handshake reply..."
REPLY_TXN=$(jq -r .reply.transaction_id < "$REPLY_FILE")

if [[ "$REPLY_TXN" == "$TXN_ID" ]]; then
    echo "Handshake SUCCESS: Transaction ID matched ($TXN_ID)"
else
    echo "Handshake FAILED: Transaction ID mismatch. Expected $TXN_ID, got $REPLY_TXN"
    cat "$REPLY_FILE"
    exit 1
fi

# 5. Test message wrapping (Inbound)
echo "Sending UUFI-wrapped message..."
WRAPPED_MSG=$(cat <<EOF
{
  "subType": "events",
  "subFolder": "pointset",
  "deviceId": "dev-1",
  "deviceRegistryId": "uufi-registry",
  "payload": {
    "version": "1.5.2",
    "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
    "points": {
      "test_point": { "present_value": 123 }
    }
  }
}
EOF
)
mosquitto_pub $MQTT_ARGS -t "/uufi/c/events/pointset" -m "$WRAPPED_MSG"

echo "UUFI Integration Test PASSED"
rm -f "$REPLY_FILE"
