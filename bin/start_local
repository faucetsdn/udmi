#!/bin/bash -e

UDMI_ROOT=$(dirname $0)/..
source $UDMI_ROOT/etc/shell_common.sh

block=
if [[ ${1:-} == block ]]; then
    block=$1
    shift
fi

[[ $# == 1 || $# == 2 ]] || usage '[block] ([site_config.json] || [site_model] [project_spec])'

if [[ $# == 1 ]]; then
    site_config=$(realpath $1)
    if [[ -d $site_config ]]; then
        site_config=$site_config/cloud_iot_config.json
    fi
    shift
else
    site_config=$(realpath $1)
    if [[ -d $site_config ]]; then
        site_config=$site_config/cloud_iot_config.json
    fi
    project_spec=$2
    shift 2
fi

if [[ ! -f $site_config ]]; then
    fail local startup requires explicit site path file.
fi
site_model=$(dirname $site_config)

# Check for missing etc/ dir for docker execution.
if [[ -d var/ && ! -d etc/ ]]; then
    ln -s var etc
fi

cd $UDMI_ROOT
UDMIS_LOG=out/udmis.log
mkdir -p out
# Do sudo now to prefetch incase it's needed later...
sudo true
echo Starting local services at $(date -u -Is) | tee $UDMIS_LOG

iot_provider=$(jq -r .iot_provider $site_config)
if [[ -n ${project_spec:-} ]]; then
    project_target=${project_spec##*/}
    iot_provider=${project_spec%/*}
    iot_provider=${iot_provider#//}
fi

if [[ $iot_provider != mqtt ]]; then
    echo Provider type $iot_provider is not a local setup, doing nothing | tee -a $UDMIS_LOG
    exit 0
fi

[[ -n ${project_target:-} ]] || project_target=$(jq -r .project_id $site_config)
registry_id=$(jq -r .registry_id $site_config)${UDMI_REGISTRY_SUFFIX:-}

echo Starting etcd... | tee -a $UDMIS_LOG
bin/start_etcd >> $UDMIS_LOG 2>&1

source $UDMI_ROOT/etc/mosquitto_ctrl.sh
mkdir -p $CERT_DIR

echo Starting mosquitto on server $project_target | tee -a $UDMIS_LOG
bin/setup_ca $site_model $project_target >> $UDMIS_LOG 2>&1
bin/start_mosquitto >> $UDMIS_LOG 2>&1

$MOSQUITTO_CTRL deleteClient $SERV_USER >> $UDMIS_LOG 2>&1 || true
$MOSQUITTO_CTRL createClient $SERV_USER -p $SERV_PASS >> $UDMIS_LOG 2>&1 || true # No client_id to allow multiple backend connections.
$MOSQUITTO_CTRL addClientRole $SERV_USER service >> $UDMIS_LOG 2>&1 || true
$MOSQUITTO_CTRL addClientRole $SERV_USER uufi >> $UDMIS_LOG 2>&1 || true

# Setup device client security (for Pubber DUT)
bin/mosquctl_device $site_model AHU-1 >> $UDMIS_LOG 2>&1

echo Starting initializing site $site_model | tee -a $UDMIS_LOG
bin/mosquctl_site $site_model >> $UDMIS_LOG 2>&1

if [[ -n ${UDMI_ALT_REGISTRY:-} ]]; then
    bin/mosquctl_site $site_model $UDMI_ALT_REGISTRY >> $UDMIS_LOG 2>&1
fi

# Global access to logs for connection tracking by UDMIS.
sudo chmod a+r /var/log/mosquitto/mosquitto.log

echo Starting udmis proper... | tee -a $UDMIS_LOG
bin/start_udmis >> $UDMIS_LOG 2>&1

echo Done with local server setup.

echo ""
echo "################################################################"
echo "UUFI Service is READY"
echo "################################################################"
echo "Connection String: mqtt://rocket:monkey@localhost:8883"
echo "CA Certificate:    $site_model/reflector/ca.crt"
echo "Client Cert:       $site_model/reflector/rsa_private.crt"
echo "Client Key:        $site_model/reflector/rsa_private.pem"
echo "################################################################"
echo ""

[[ -z $block ]] || (echo Blocking until termination. && tail -f /dev/null)
