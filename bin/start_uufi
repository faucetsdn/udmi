#!/bin/bash -e
# Start a local UUFI development environment.

UDMI_ROOT=$(dirname $0)/..
source $UDMI_ROOT/etc/shell_common.sh

# Use a default site model for local testing if not provided
SITE_MODEL=${1:-sites/udmi_site_model}
PROJECT_ID=${2:-//mqtt/localhost}

echo "Starting UUFI development environment..."
echo "Site Model: $SITE_MODEL"
echo "Project ID: $PROJECT_ID"

# Start the local environment (MQTT, etcd, UDMIS)
# UUFI is now a base capability enabled in local_pod.json
bin/start_local $SITE_MODEL $PROJECT_ID &
LOCAL_PID=$!

trap "kill $LOCAL_PID 2>/dev/null || true; exit" INT TERM

# Wait for UDMIS pod ready signal
echo -n "Waiting for UDMIS service pod to signal ready..."
POD_READY=/tmp/pod_ready.txt
TIMEOUT=60
while [[ ! -f $POD_READY && $TIMEOUT -gt 0 ]]; do
    echo -n "."
    sleep 1
    TIMEOUT=$((TIMEOUT - 1))
done
echo ""

if [[ -f $POD_READY ]]; then
    echo ""
    echo "################################################################"
    echo "UUFI Service is READY"
    echo "################################################################"
    echo "Connection String: mqtt://rocket:monkey@localhost:8883"
    echo "CA Certificate:    $SITE_MODEL/reflector/ca.crt"
    echo "Client Cert:       $SITE_MODEL/reflector/rsa_private.crt"
    echo "Client Key:        $SITE_MODEL/reflector/rsa_private.pem"
    echo "################################################################"
    echo ""
    echo "You can now run your own UUFI client, 'bin/uufi_test_client', or 'bin/observe_uufi' in another terminal."
else
    echo "UDMIS failed to signal ready. Check out/udmis.log for errors."
fi

wait $LOCAL_PID
