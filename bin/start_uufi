#!/bin/bash -e

# Start a local UUFI development environment.
# This script sets up a local MQTT broker and starts UDMIS with the UUFI processor enabled.

UDMI_ROOT=$(dirname $0)/..
source $UDMI_ROOT/etc/shell_common.sh

export UDMI_ROOT
export UDMIS_CONFIG=udmis/etc/uufi_pod.json

# Use a default site model for local testing if not provided
SITE_MODEL=${1:-sites/uufi_site_model}
PROJECT_ID=${2:-vibrant}
REGISTRY_ID="uufi-registry"

echo "Starting UUFI development environment..."
echo "Site Model: $SITE_MODEL"
echo "Project ID: $PROJECT_ID"

# 1. Start local MQTT and basic services
if [[ ! -d $SITE_MODEL || ! -f $SITE_MODEL/cloud_iot_config.json ]]; then
    echo "Creating basic site model for UUFI testing..."
    mkdir -p $SITE_MODEL/reflector
    cat <<EOF > $SITE_MODEL/cloud_iot_config.json
{
  "project_id": "$PROJECT_ID",
  "registry_id": "$REGISTRY_ID",
  "iot_provider": "mqtt"
}
EOF
    # Generate initial keys for the reflector as setup_ca expects them
    (cd $SITE_MODEL/reflector && $UDMI_ROOT/bin/keygen RS256 .)
fi

# Initialize registry_id for mosquitto_ctrl.sh
export registry_id=$(jq -r .registry_id $SITE_MODEL/cloud_iot_config.json || echo "$REGISTRY_ID")
source $UDMI_ROOT/etc/mosquitto_ctrl.sh

# Start the local environment (MQTT, etcd, etc.)
echo "Initializing local services (MQTT, etcd, UDMIS)..."
bin/start_local $SITE_MODEL mqtt/$PROJECT_ID &
LOCAL_PID=$!

trap "kill $LOCAL_PID 2>/dev/null || true; exit" INT TERM

# Wait for system certificates to be generated by setup_ca (run by start_local)
SYS_CA_CERT="/etc/mosquitto/certs/ca.crt"
echo -n "Waiting for system certificates to be generated..."
TIMEOUT=30
while [[ ! -s $SYS_CA_CERT && $TIMEOUT -gt 0 ]]; do
    echo -n "."
    sleep 1
    TIMEOUT=$((TIMEOUT - 1))
done
echo ""

if [[ ! -s $SYS_CA_CERT ]]; then
    echo "ERROR: System certificates not found in $SYS_CA_CERT. Check out/udmis.log."
    kill $LOCAL_PID; exit 1
fi

# Copy generated certs back to site model for local client use
echo "Syncing certificates to local site model $SITE_MODEL/reflector..."
sudo cp /etc/mosquitto/certs/ca.crt $SITE_MODEL/reflector/
sudo cp /etc/mosquitto/certs/rsa_private.crt $SITE_MODEL/reflector/
sudo chown $(id -u):$(id -g) $SITE_MODEL/reflector/*

# Wait for local setup to create MQTT clients and roles
echo -n "Waiting for MQTT security and ACLs..."
TIMEOUT=30
while ! $MOSQUITTO_CTRL listClients 2>/dev/null | grep -q $SERV_USER && [[ $TIMEOUT -gt 0 ]]; do
    echo -n "."
    sleep 1
    TIMEOUT=$((TIMEOUT - 1))
done
echo ""

# Ensure the 'rocket' user exists and has UUFI access
echo "Configuring UUFI client security..."
$MOSQUITTO_CTRL createClient rocket -p monkey || true
$MOSQUITTO_CTRL addClientRole rocket uufi || true

# Wait for UDMIS pod ready signal
echo -n "Waiting for UDMIS service pod to signal ready..."
POD_READY=/tmp/pod_ready.txt
TIMEOUT=60
while [[ ! -f $POD_READY && $TIMEOUT -gt 0 ]]; do
    echo -n "."
    sleep 1
    TIMEOUT=$((TIMEOUT - 1))
done
echo ""

if [[ -f $POD_READY ]]; then
    echo ""
    echo "################################################################"
    echo "UUFI Service is READY"
    echo "################################################################"
    echo "Connection String: mqtt://rocket:monkey@localhost:8883"
    echo "CA Certificate:    $SITE_MODEL/reflector/ca.crt"
    echo "Client Cert:       $SITE_MODEL/reflector/rsa_private.crt"
    echo "Client Key:        $SITE_MODEL/reflector/rsa_private.pem"
    echo "Topic Prefix:      (none)"
    echo "################################################################"
    echo ""
    echo "You can now run 'bin/test_uufi' or 'bin/observe_uufi' in another terminal."
else
    echo "UDMIS failed to signal ready within 30 seconds. Check out/udmis.log for errors."
fi

# Keep script running if started in background or wait for local process
wait $LOCAL_PID
