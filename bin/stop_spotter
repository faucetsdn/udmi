#!/bin/bash
# Stop script for UDMI Spotter Agent

set -eo pipefail

SERIAL_NO=""
MODE="all"

function show_help() {
    echo "Usage: $0 [SERIAL_NO] [options]"
    echo ""
    echo "Arguments:"
    echo "  SERIAL_NO                    Specific Spotter serial number to stop (optional, default: stops all)"
    echo ""
    echo "Options:"
    echo "  --mode <container|local|all> Specify execution environment to stop (default: all)"
    echo "  -h, --help                   Show this help message"
}

# Parse positional argument if present
if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
    SERIAL_NO="$1"
    shift
fi

# Parse remaining options
while [[ $# -gt 0 ]]; do
    case "$1" in
        --mode)
            MODE="$2"
            shift 2
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            echo "Error: Unknown option $1"
            show_help
            exit 1
            ;;
    esac
done

stop_container() {
    local search_filter="udmi-spotter-agent"
    if [[ -n "${SERIAL_NO}" ]]; then
        search_filter="udmi-spotter-agent-${SERIAL_NO}"
    fi

    local matching_containers
    matching_containers=$(docker ps -q --filter "name=${search_filter}" || true)

    if [[ -n "${matching_containers}" ]]; then
        echo "Stopping matching Spotter Agent container(s) (${search_filter})..."
        docker stop ${matching_containers}
        echo "Container(s) stopped successfully."
    else
        echo "No running Spotter Agent container found matching '${search_filter}'."
    fi
}

stop_local() {
    echo "Searching for local supervised Spotter processes..."
    
    local pgrep_pattern="supervisor.sh"
    if [[ -n "${SERIAL_NO}" ]]; then
        pgrep_pattern="supervisor.sh .*--serial_no ${SERIAL_NO}"
    fi

    local supervisor_pids
    supervisor_pids=$(pgrep -f "${pgrep_pattern}" || true)
    
    if [[ -n "${supervisor_pids}" ]]; then
        echo "Found running local supervisor(s) matching '${SERIAL_NO:-all}' with PID(s): ${supervisor_pids}"
        for pid in ${supervisor_pids}; do
            echo "Sending SIGTERM to supervisor process ${pid}..."
            kill -TERM "${pid}" 2>/dev/null || true
        done
        
        echo "Waiting for child processes to terminate gracefully..."
        sleep 2
        echo "Local services stopped."
    else
        # Fallback search directly for agent.py processes if supervisor wasn't found
        local agent_pattern="agent.py"
        if [[ -n "${SERIAL_NO}" ]]; then
            agent_pattern="agent.py .*--serial_no ${SERIAL_NO}"
        fi
        local agent_pids
        agent_pids=$(pgrep -f "${agent_pattern}" || true)
        if [[ -n "${agent_pids}" ]]; then
            echo "Found orphan Spotter Agent process(es) with PID(s): ${agent_pids}"
            for pid in ${agent_pids}; do
                echo "Sending SIGTERM to agent process ${pid}..."
                kill -TERM "${pid}" 2>/dev/null || true
            done
        fi
        
        local legacy_pids
        legacy_pids=$(pgrep -f "discoverynode/src/main.py" || true)
        if [[ -n "${legacy_pids}" && -z "${SERIAL_NO}" ]]; then
            echo "Found orphan Legacy Discovery process(es) with PID(s): ${legacy_pids}"
            for pid in ${legacy_pids}; do
                echo "Sending SIGTERM to discovery process ${pid}..."
                kill -TERM "${pid}" 2>/dev/null || true
            done
        fi
        
        if [[ -z "${agent_pids}" && -z "${legacy_pids}" ]]; then
            echo "No active local Spotter processes found matching '${SERIAL_NO:-all}'."
        fi
    fi
}

if [[ "${MODE}" == "container" ]]; then
    stop_container
elif [[ "${MODE}" == "local" ]]; then
    stop_local
elif [[ "${MODE}" == "all" ]]; then
    stop_container
    echo ""
    stop_local
else
    echo "Error: Invalid mode '${MODE}'."
    show_help
    exit 1
fi
