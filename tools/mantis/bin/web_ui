#!/bin/bash -e
#
# Launcher wrapper for Project Mantis Web Control Center & Presentation UI.
# Automatically activates virtualenv and starts the HTTP/API server,
# then launches the local web browser to showcase the tool.

# Resolve directories
MANTIS_BIN=$(dirname $0)
MANTIS_DIR=$(realpath $MANTIS_BIN/..)
UDMI_ROOT=$(realpath $MANTIS_DIR/..)

PORT=${1:-8000}

cd $UDMI_ROOT

# Activate virtualenv
if [[ -f venv/bin/activate ]]; then
    source venv/bin/activate
    export PYTHONPATH="$MANTIS_DIR/src:$PYTHONPATH"
else
    echo "Warning: Project virtual environment not found at '$UDMI_ROOT/venv'." >&2
    echo "Attempting execution using system python3..." >&2
fi

# Ensure server file is executable
chmod +x $MANTIS_DIR/web/server.py 2>/dev/null || true

# Start background thread to open web browser after a small pause
(
    sleep 1.2
    echo -e "\n[WEB UI] Automatically opening browser for presentation..."
    if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "http://localhost:${PORT}" >/dev/null 2>&1 &
    elif command -v open >/dev/null 2>&1; then
        open "http://localhost:${PORT}" >/dev/null 2>&1 &
    else
        echo -e "\n[WEB UI] Please open this address in your browser: http://localhost:${PORT}\n"
    fi
) &

# Launch python server (blocking)
python3 $MANTIS_DIR/web/server.py "$PORT"
