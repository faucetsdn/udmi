{
  "$udmi_version": "1.5.2",
  "title": "Alarmset Config",
  "description": "[Alarmset Config Documentation](../docs/messages/alarmset.md#config)",
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "timestamp": {
      "description": "RFC 3339 UTC timestamp the configuration was generated",
      "type": "string",
      "format": "date-time",
      "examples": ["2019-01-17T14:02:29.364Z"]
    },
    "version": {
      "description": "Version of the UDMI schema",
      "type": "string"
    },
    "alarms": {
      "description": "The alarms defined in this dictionary is the authoritative source indicating the representative alarms for the device. [Alarmset doumentation](../docs/messages/alarmset.md)",
      "additionalProperties": false,
      "existingJavaType": "java.util.HashMap<String, AlarmAlarmsetConfig>",
      "patternProperties": {
        "^[a-z][a-z0-9]*(_[a-z0-9]+)*$": {
          "$ref": "file:config_alarmset_alarm.json#"
        }
      }
    }
  }
}
