#!/bin/bash

# Test suite for container process supervisor (supervisor.sh)

# Exit immediately if a command exits with a non-zero status, except in check functions
set -u

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    echo "Usage: $0"
    echo ""
    echo "Validates the container process supervisor (supervisor.sh) behaviors:"
    echo "1. Normal Lifecycle & Graceful Shutdown: Verifies SIGTERM propagation to child processes."
    echo "2. Legacy Node Crash Recovery: Verifies container exit with code 101 when legacy.py crashes."
    echo "3. Spotter Agent Crash Recovery: Verifies container exit with code 102 when spotter.py crashes."
    echo ""
    echo "Prerequisites:"
    echo "- Must run on Linux with Python 3 installed."
    exit 0
fi

SUPERVISOR_PATH=$(realpath "$(dirname "$0")/../container/supervisor.sh")
FAILED_TESTS=0

# Helper to create temporary environment and mock scripts
setup_temp_dir() {
    TEST_DIR=$(mktemp -d)
    CONFIG_FILE="$TEST_DIR/config.json"
    echo '{"log_level": "INFO"}' > "$CONFIG_FILE"
}

cleanup_temp_dir() {
    rm -rf "$TEST_DIR"
}

create_mock_script() {
    local name=$1
    local behavior=$2
    local path="$TEST_DIR/$name"
    
    cat <<EOF > "$path"
#!/usr/bin/env python3
import os
import sys
import time
import signal

print(f"MOCK START: $name (PID: {os.getpid()})", flush=True)

def handler(signum, frame):
    print(f"MOCK SIGTERM: $name (PID: {os.getpid()})", flush=True)
    sys.exit(0)

signal.signal(signal.SIGTERM, handler)
signal.signal(signal.SIGINT, handler)

$behavior
print(f"MOCK EXIT: $name (PID: {os.getpid()})", flush=True)
EOF
    chmod +x "$path"
    echo "$path"
}

run_test_case() {
    local _rtc_test_name=$1
    local _rtc_legacy_behavior=$2
    local _rtc_spotter_behavior=$3
    local _rtc_action=$4
    
    setup_temp_dir
    
    local _rtc_legacy_path
    local _rtc_spotter_path
    _rtc_legacy_path=$(create_mock_script "legacy.py" "$_rtc_legacy_behavior")
    _rtc_spotter_path=$(create_mock_script "spotter.py" "$_rtc_spotter_behavior")
    
    # Run supervisor in background
    local _rtc_stdout_log="$TEST_DIR/stdout.log"
    local _rtc_stderr_log="$TEST_DIR/stderr.log"
    
    LEGACY_PATH="$_rtc_legacy_path" \
    SPOTTER_PATH="$_rtc_spotter_path" \
    LEGACY_VENV="python3" \
    SPOTTER_VENV="python3" \
    "$SUPERVISOR_PATH" --config_file "$CONFIG_FILE" > "$_rtc_stdout_log" 2> "$_rtc_stderr_log" &
    local _rtc_supervisor_pid=$!
    
    local _rtc_exit_code
    if [ "$_rtc_action" = "shutdown" ]; then
        # Let processes start
        sleep 2
        # Send SIGTERM to supervisor
        kill -TERM "$_rtc_supervisor_pid"
        wait "$_rtc_supervisor_pid"
        _rtc_exit_code=$?
    else
        # Just wait for supervisor to exit due to child crash
        wait "$_rtc_supervisor_pid"
        _rtc_exit_code=$?
    fi
    
    local _rtc_output
    _rtc_output=$(cat "$_rtc_stdout_log")
    local _rtc_errors
    _rtc_errors=$(cat "$_rtc_stderr_log")
    
    cleanup_temp_dir
    
    # Return results using dynamic references
    eval "$5=\$_rtc_exit_code"
    eval "$6=\$_rtc_output"
    eval "$7=\$_rtc_errors"
}

# --- TEST 1: Normal Lifecycle and Shutdown ---
test_normal_lifecycle_and_shutdown() {
    echo -n "Running test_normal_lifecycle_and_shutdown... "
    local exit_code=""
    local output=""
    local errors=""
    run_test_case "normal" "time.sleep(60)" "time.sleep(60)" "shutdown" exit_code output errors
    
    if [ "$exit_code" -ne 0 ]; then
        echo "FAIL (Expected exit code 0, got $exit_code)"
        echo "STDOUT: $output"
        echo "STDERR: $errors"
        FAILED_TESTS=$((FAILED_TESTS + 1))
        return 1
    fi
    
    if [[ ! "$output" =~ "Supervisor: Received shutdown signal" ]] || [[ ! "$output" =~ "Supervisor: All child processes terminated. Exiting." ]]; then
        echo "FAIL (Logs missing shutdown confirmation)"
        echo "STDOUT: $output"
        echo "STDERR: $errors"
        FAILED_TESTS=$((FAILED_TESTS + 1))
        return 1
    fi
    echo "PASS"
}

# --- TEST 2: Legacy Node Crash ---
test_legacy_crash() {
    echo -n "Running test_legacy_crash... "
    local exit_code=""
    local output=""
    local errors=""
    run_test_case "legacy_crash" "sys.exit(1)" "time.sleep(60)" "wait" exit_code output errors
    
    if [ "$exit_code" -ne 101 ]; then
        echo "FAIL (Expected exit code 101, got $exit_code)"
        echo "STDOUT: $output"
        echo "STDERR: $errors"
        FAILED_TESTS=$((FAILED_TESTS + 1))
        return 1
    fi
    
    if [[ ! "$output" =~ "Supervisor: Fatal crash detected on legacy node. Restarting container." ]]; then
        echo "FAIL (Logs missing crash detection notice)"
        echo "STDOUT: $output"
        echo "STDERR: $errors"
        FAILED_TESTS=$((FAILED_TESTS + 1))
        return 1
    fi
    echo "PASS"
}

# --- TEST 3: Spotter Agent Crash ---
test_spotter_crash() {
    echo -n "Running test_spotter_crash... "
    local exit_code=""
    local output=""
    local errors=""
    run_test_case "spotter_crash" "time.sleep(60)" "sys.exit(2)" "wait" exit_code output errors
    
    if [ "$exit_code" -ne 102 ]; then
        echo "FAIL (Expected exit code 102, got $exit_code)"
        echo "STDOUT: $output"
        echo "STDERR: $errors"
        FAILED_TESTS=$((FAILED_TESTS + 1))
        return 1
    fi
    
    if [[ ! "$output" =~ "Supervisor: Fatal crash detected on Spotter agent. Restarting container." ]]; then
        echo "FAIL (Logs missing crash detection notice)"
        echo "STDOUT: $output"
        echo "STDERR: $errors"
        FAILED_TESTS=$((FAILED_TESTS + 1))
        return 1
    fi
    echo "PASS"
}

# Run all tests
test_normal_lifecycle_and_shutdown
test_legacy_crash
test_spotter_crash

if [ "$FAILED_TESTS" -eq 0 ]; then
    echo "All supervisor tests passed successfully!"
    exit 0
else
    echo "$FAILED_TESTS supervisor test(s) failed."
    exit 1
fi
