#!/bin/bash -e
#
# Launcher wrapper for Project Mantis AI Diagnostics / Triage Component (Stage 3).
# Automatically activates the virtualenv and executes
# the Python diagnose module.
#

# Your CLI tool logic starts here
echo "Initializing mantis..."

# Resolve parent directory structure
MANTIS_BIN=$(dirname $0)
MANTIS_DIR=$(realpath $MANTIS_BIN/..)
UDMI_ROOT=$(realpath $MANTIS_DIR/../..)

cd $UDMI_ROOT

# 1. Guarantee execution permissions
chmod +x $MANTIS_DIR/bin/diagnose 2>/dev/null || true
chmod +x $MANTIS_DIR/src/app/main.py 2>/dev/null || true

# 2. Activate virtualenv
if [[ -f venv/bin/activate ]]; then
    source venv/bin/activate
    export PYTHONPATH="$UDMI_ROOT/tools:$MANTIS_DIR/src:$PYTHONPATH"
else
    echo "Error: Project virtual environment not found at '$UDMI_ROOT/venv'." >&2
    echo "Please run 'bin/setup_base' first to initialize dependencies." >&2
    exit 1
fi

# 3. Call Python module forwarding all arguments
python3 -m mantis.src.app.main "$@"
