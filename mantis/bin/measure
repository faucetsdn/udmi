#!/bin/bash -e
#
# Launcher wrapper for Project Mantis flakiness measurement.
# Automatically activates the repository virtualenv and executes
# the Python orchestrator.
#

# Resolve parent directory structure
MANTIS_BIN=$(dirname $0)
MANTIS_DIR=$(realpath $MANTIS_BIN/..)
UDMI_ROOT=$(realpath $MANTIS_DIR/..)

cd $UDMI_ROOT

# 1. Guarantee execution permissions on orchestrator and measure script
chmod +x $MANTIS_DIR/bin/measure 2>/dev/null || true
chmod +x $MANTIS_DIR/src/orchestrator.py 2>/dev/null || true

# 2. Activate virtualenv if exists
if [[ -f venv/bin/activate ]]; then
    source venv/bin/activate
else
    echo "Error: Project virtual environment not found at '$UDMI_ROOT/venv'." >&2
    echo "Please run 'bin/setup_base' first to initialize dependencies." >&2
    exit 1
fi

# 3. Call orchestrator forwarding all arguments
python3 $MANTIS_DIR/src/orchestrator.py "$@"
