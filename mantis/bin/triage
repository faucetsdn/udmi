#!/bin/bash -e
#
# Unified Project Mantis Triage Utility
# Automatically unpacks, evaluates stability, and triages failures for manually downloaded bundles.
#

# Resolve directories
MANTIS_BIN=$(dirname $0)
MANTIS_DIR=$(realpath $MANTIS_BIN/..)
UDMI_ROOT=$(realpath $MANTIS_DIR/..)

cd $UDMI_ROOT

# Initialize defaults
TEST_CASE=""
DEVICE_ID=""
BUNDLE_PATH=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -t|--test)
            TEST_CASE="$2"
            shift 2
            ;;
        -d|--device)
            DEVICE_ID="$2"
            shift 2
            ;;
        *)
            if [[ -z $BUNDLE_PATH ]]; then
                BUNDLE_PATH="$1"
                shift
            else
                echo "Error: Unknown argument $1" >&2
                exit 1
            fi
            ;;
    esac
done

# Check required positional argument
if [[ -z $BUNDLE_PATH ]]; then
    echo "Error: No bundle path or directory supplied." >&2
    echo "Usage: bin/triage <bundle_zip_tgz_or_directory> [-t|--test <test_case_name>] [-d|--device <device_id>]" >&2
    exit 1
fi

INPUT_PATH=$(realpath "$BUNDLE_PATH")

if [[ ! -e $INPUT_PATH ]]; then
    echo "Error: Input path '$BUNDLE_PATH' does not exist." >&2
    exit 1
fi

# Activate virtualenv
if [[ -f venv/bin/activate ]]; then
    source venv/bin/activate
    export PYTHONPATH="$MANTIS_DIR/src:$PYTHONPATH"
else
    echo "Error: Project virtual environment not found at '$UDMI_ROOT/venv'." >&2
    echo "Please run 'bin/setup_base' first to initialize dependencies." >&2
    exit 1
fi

# Determine input target directory
TARGET_DIR=""

if [[ -d $INPUT_PATH ]]; then
    TARGET_DIR=$INPUT_PATH
    echo "Using existing directory: $TARGET_DIR"
else
    # It's a file (zip or tgz)
    filename=$(basename "$INPUT_PATH")
    clean_name="${filename%.*}"
    clean_name="${clean_name%.tar}" # strip double extensions like .tar.gz
    
    TARGET_DIR="$MANTIS_DIR/out/test_bundles/${clean_name}"
    
    if [[ ! -d $TARGET_DIR ]]; then
        echo "Creating workspace directory: $TARGET_DIR"
        mkdir -p "$TARGET_DIR"
        if [[ "$INPUT_PATH" =~ \.zip$ ]]; then
            echo "Unzipping parent archive to workspace: $TARGET_DIR"
            unzip -q -o "$INPUT_PATH" -d "$TARGET_DIR"
        else
            cp "$INPUT_PATH" "$TARGET_DIR/"
        fi
    else
        echo "Using cached workspace directory: $TARGET_DIR"
    fi
fi

# Guarantee execution permissions on components
chmod +x $MANTIS_DIR/bin/evaluate_stability 2>/dev/null || true
chmod +x $MANTIS_DIR/bin/diagnose 2>/dev/null || true

# 4. Run Stability Metric Evaluation
echo
echo "============================================================="
echo "📈 STEP 1: Evaluating Stability & Metric Compilation..."
echo "============================================================="
python3 -m mantis.src.util.eval_sequencer_stability.main -i "$TARGET_DIR"

# 5. Run AI Diagnostic Failure Triage
echo
echo "============================================================="
echo "🤖 STEP 2: Running AI Diagnostic Failure Triage..."
echo "============================================================="
if [[ -f "$TARGET_DIR/triage_manifest.json" ]]; then
    echo "Manifest hand-off detected: loading failed/flaky tests from $TARGET_DIR/triage_manifest.json"
    diagnose_args=("-m" "$TARGET_DIR/triage_manifest.json")
else
    echo "No manifest found. Falling back to scanning directory: $TARGET_DIR"
    diagnose_args=("-i" "$TARGET_DIR")
fi

if [[ -n $TEST_CASE ]]; then
    diagnose_args+=("-t" "$TEST_CASE")
fi
if [[ -n $DEVICE_ID ]]; then
    diagnose_args+=("-d" "$DEVICE_ID")
fi

python3 -m mantis.src.triage.impl.main "${diagnose_args[@]}"

echo
echo "============================================================="
echo "🎉 Mantis Unified Triage completed successfully!"
echo "============================================================="
echo "Check 'mantis/out/' for compiled stability flakiness reports."
echo "Check 'mantis/out/diagnose/' for AI diagnostic defect analysis reports."
echo "============================================================="
echo
